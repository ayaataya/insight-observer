## Copy this file to .env and fill in your key.
## .env is gitignored — never commit real API keys.

# Your OpenAI API key (used directly from the browser for the vision,
# interview, and final-synthesis calls).
VITE_OPENAI_API_KEY=

# Optional: override the model used for all AI calls. Defaults to gpt-5.6
# as required by the assignment if left unset.
VITE_OPENAI_MODEL=gpt-5.6
